  "types": [
    {
      "name": "CommitmentAccount",
      "docs": [
        "Commitment account - its existence proves the commitment has been deposited.",
        "PDA seeds: [b\"commitment\", mixer_pool.key(), commitment]"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "DepositEvent",
      "type": {
        "kind": "struct",
        "fields": [
