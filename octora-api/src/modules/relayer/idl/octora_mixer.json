            "name": "commitment",
            "type": {
              "array": [
                "u8",
                32
              ]
            }
          },
          {
            "name": "leaf_index",
            "type": "u32"
          },
          {
            "name": "timestamp",
            "type": "i64"
          }
        ]
      }
    },
    {
      "name": "MixerPool",
      "docs": [
        "Main mixer pool account (also serves as SOL vault).",
        "PDA seeds: [b\"mixer_pool\", denomination.to_le_bytes()]"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "authority",
            "docs": [
              "Admin authority who can pause/unpause the pool"
            ],
            "type": "pubkey"
          },
          {
            "name": "denomination",
            "docs": [
              "Fixed deposit denomination in lamports (e.g., 1 SOL = 1_000_000_000)"
            ],
            "type": "u64"
          },
          {
            "name": "next_leaf_index",
            "docs": [
              "Next available leaf index in the Merkle tree"
            ],
            "type": "u32"
          },
          {
            "name": "current_root_index",
            "docs": [
              "Current index into the root_history ring buffer"
            ],
            "type": "u8"
          },
          {
            "name": "root_history",
            "docs": [
              "Ring buffer of recent valid Merkle roots"
            ],
            "type": {
              "array": [
                {
                  "array": [
                    "u8",
                    32
                  ]
                },
                30
              ]
            }
          },
          {
            "name": "filled_subtrees",
            "docs": [
              "Cached left-side subtree hashes for incremental insertion"
            ],
            "type": {
              "array": [
                {
                  "array": [
                    "u8",
                    32
                  ]
                },
                20
              ]
            }
          },
          {
            "name": "is_paused",
            "docs": [
              "Emergency pause flag"
            ],
            "type": "bool"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump seed"
            ],
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "NullifierAccount",
      "docs": [
        "Nullifier account - its existence proves the nullifier has been spent.",
        "PDA seeds: [b\"nullifier\", mixer_pool.key(), nullifier_hash]"
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
