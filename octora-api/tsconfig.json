{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "#app": ["src/app.ts"],
      "#common/*": ["src/common/*"],
      "#domain": ["src/domain/index.ts"],
      "#domain/*": ["src/domain/*"],
      "#modules/*": ["src/modules/*"],
      "#infra/*": ["src/infra/*"],
      "#test-kit": ["src/test-kit/index.ts"],
      "#test-kit/*": ["src/test-kit/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
